// RFC 0005 fixture: exercises the scalar shorthand marker (`!`), the `name`
// identity field, and optional shorthand (`?!`), alongside inheritance, modifiers,
// a nested block, and list fields. Guarded by a parse + extract test so it can no
// longer rot. (This is an nml language fixture, not a copy of any consumer schema.)

model accessControlled:
    |allow []role
    |deny []role

enum httpMethod:
    - "GET"
    - "POST"
    - "PUT"
    - "DELETE"
    - "PATCH"

model resource is accessControlled:
    path path+
    method httpMethod = "GET"

model endpoint is accessControlled:
    address string+

    .healthCheck:
        path path

model service is accessControlled:
    localMount path
    resources []resource
    endpoints []endpoint

model role:
    name string+
    description string?
    members []role?

model command:
    name string
    run string?+
