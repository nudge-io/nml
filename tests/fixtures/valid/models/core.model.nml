model accessControlled:
    |allow []role
    |deny []role

enum httpMethod:
    - "GET"
    - "POST"
    - "PUT"
    - "DELETE"
    - "PATCH"

model resource is accessControlled:
    path path <shorthand>
    method httpMethod = "GET"

model endpoint is accessControlled:
    address string

    .healthCheck:
        path path

model service is accessControlled:
    localMount path
    resources []resource
    endpoints []endpoint

model role:
    label string
    description string?
    members []role?
